# Server port (Render/Railway/etc. inject their own PORT — this is the fallback)
PORT=5000

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated list of allowed frontend origins for CORS.
# Leave empty in local dev to allow any origin. In production set the deployed URL, e.g.:
# CLIENT_URL=https://your-frontend.vercel.app
CLIENT_URL=
